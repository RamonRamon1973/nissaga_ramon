name: Mantenir Supabase actiu

on:
  schedule:
    - cron: "0 8 * * 1,4"   # dilluns i dijous a les 08:00 UTC
  workflow_dispatch:         # també es pot executar manualment des de GitHub

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Fer una petició de lectura a Supabase
        run: |
          curl -s "${{ secrets.SUPABASE_URL }}/rest/v1/persons?select=id&limit=1" \
            -H "apikey: ${{ secrets.SUPABASE_ANON_KEY }}" \
            -H "Authorization: Bearer ${{ secrets.SUPABASE_ANON_KEY }}"
